generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A person who owns a set of quiz questions.
/// App rule: a user may own at most 20 questions (enforced in application code,
/// since SQLite/Prisma cannot express a per-parent row-count limit).
model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  questions Question[]
  attempts  QuizAttempt[]
}

/// One play-through of a well-wisher's quiz: how many questions a player got
/// right out of the total. Used to rank which well-wisher is "known best".
model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  total     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A single quiz question belonging to a user.
/// INVARIANT: every question has EXACTLY 3 options labelled "a", "b", "c",
/// exactly one of which is correct. SQLite can't enforce the count, so
/// always create/update a question and its 3 options together in one
/// transaction (see createQuestion in src/lib/quiz.ts).
model Question {
  id        String   @id @default(cuid())
  text      String
  position  Int
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  options   Option[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, position])
  @@index([userId])
}

/// One answer choice for a question. `label` is "a", "b", or "c".
model Option {
  id         String   @id @default(cuid())
  label      String
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, label])
  @@index([questionId])
}
